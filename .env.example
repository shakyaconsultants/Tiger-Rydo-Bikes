# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/tiger-rydo

# Dealer JWT secret (change in production)
DEALER_JWT_SECRET=your-secret-key-change-in-production

# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/tiger-rydo?retryWrites=true&w=majority

# Node.js 24+ on Windows: npm scripts use NODE_OPTIONS=--use-system-ca for Atlas TLS.
# Always keep secrets in .env.local — never commit real credentials to .env.example
